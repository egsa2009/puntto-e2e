{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "commonjs",
    "moduleResolution":  "node",
    "lib":               ["ES2020", "DOM"],
    "strict":            true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "outDir":            "dist",
    "baseUrl":           ".",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "*.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright-report"]
}
