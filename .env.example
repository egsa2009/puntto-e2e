# ─────────────────────────────────────────────────────────────────────────────
# Puntto E2E — Variables de entorno
# Copia este archivo a .env.test y rellena los valores.
# NUNCA subas .env.test a git (ya está en .gitignore).
#
# RECOMENDACIÓN: crea un proyecto Supabase separado llamado "puntto-test"
# y corre las migraciones. Así las pruebas no tocan datos de producción.
# ─────────────────────────────────────────────────────────────────────────────

# URLs de las apps (en local apuntan a los servidores Vite; en CI a los deploys)
ADMIN_URL=https://puntto-admin.vercel.app
CLIENT_URL=https://puntto-client.vercel.app
POS_URL=https://puntto-pos.vercel.app

# Slug del tenant de prueba (debe existir en tu Supabase de test)
# El cliente accede a: CLIENT_URL/:TEST_SLUG/login
TEST_SLUG=momotea

# ─── Supabase de TEST (proyecto separado recomendado) ────────────────────────
# Obtén estas claves en: supabase.com > tu proyecto test > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...   # service_role key (no la anon key)

# ─── Credenciales de usuarios de prueba ─────────────────────────────────────
# Estos usuarios deben existir en tu Supabase de test
TEST_ADMIN_EMAIL=admin2@loyalflow.com
TEST_ADMIN_PASSWORD=MomoDiver2026*

TEST_CASHIER_EMAIL=empleado@loyalflow.com
TEST_CASHIER_PASSWORD=MomoDiver2026*

TEST_CLIENT_EMAIL=test2@loyalflow.com
TEST_CLIENT_PASSWORD=EGsa3472*
