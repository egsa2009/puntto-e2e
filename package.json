{
  "name": "puntto-e2e",
  "version": "1.0.0",
  "description": "Pruebas E2E para Puntto (admin, client, POS)",
  "scripts": {
    "test": "playwright test",
    "test:admin": "playwright test tests/admin",
    "test:client": "playwright test tests/client",
    "test:pos": "playwright test tests/pos",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "codegen:admin": "playwright codegen $ADMIN_URL",
    "codegen:client": "playwright codegen $CLIENT_URL",
    "codegen:pos": "playwright codegen $POS_URL"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@supabase/supabase-js": "^2.43.0",
    "dotenv": "^16.4.5",
    "typescript": "^6.0.2"
  }
}
